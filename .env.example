# bizbize - Çevre Değişkenleri Şablonu
# Bu dosyayı '.env' veya '.env.local' olarak kopyalayın ve kendi Firebase bilgilerinizi girin.

# ─── Firebase Altyapısı Yapılandırması ───
VITE_FIREBASE_API_KEY=AIzaSyA1... (Kendi Firebase API Anahtarınız)
VITE_FIREBASE_AUTH_DOMAIN=bizbize-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=bizbize-app
VITE_FIREBASE_STORAGE_BUCKET=bizbize-app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef...

# ─── Gemini Yapay Zeka (AI) Asistanı Yapılandırması ───
GEMINI_API_KEY=AIzaSyB... (Kendi Gemini API Anahtarınız)
